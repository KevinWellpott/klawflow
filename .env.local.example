# ─────────────────────────────────────────────
# Klawflow – Umgebungsvariablen
# Kopiere diese Datei zu .env.local und fülle die Werte aus.
# .env.local wird NIEMALS ins Git committed.
# ─────────────────────────────────────────────

# ── E-Mail (Resend) ───────────────────────────
# Account: https://resend.com
# API Key unter: Settings → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Absender-Adresse (muss in Resend verifiziert sein)
RESEND_FROM_EMAIL=noreply@klawflow.de

# ── Double Opt-In ─────────────────────────────
# Beliebiger geheimer Schlüssel für HMAC-Token (min. 32 Zeichen)
# Generieren: openssl rand -hex 32
CONFIRMATION_SECRET=ersetze-mich-mit-einem-langen-geheimen-string

# ── App URL ───────────────────────────────────
# Produktions-URL (ohne trailing slash)
NEXT_PUBLIC_BASE_URL=https://deinedomain.de

# ── CRM (Pfad C – Calendly Webhook) ──────────
# Webhook-URL deines CRMs (z.B. Make/Zapier/HubSpot)
# Dieser Endpunkt empfängt: { source, name, email, scheduled_at, tags }
CRM_WEBHOOK_URL=https://hook.eu1.make.com/xxxxxxxxxxxx
